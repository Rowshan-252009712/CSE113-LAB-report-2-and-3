#include<stdio.h>
int palindrome(int n){
int original=n,rev=0;
while(n!=0){
    rev=rev*10+(n%10);
    n=n/10;
}
if(original==rev){
    return 1;
}
else {
    return 0;
}
}
int main(){
int x;
printf("Enter a number: ");
scanf("%d",&x);
if(palindrome(x)){
    printf("The number is a palindrome.");
}
else{
    printf("The number is not palindrome");
}
return 0;
}
